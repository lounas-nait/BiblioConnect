{% extends 'base.html.twig' %}

{% block title %}BiblioConnect - Accueil{% endblock %}

{% block body %}
<div class="hero">
    <div class="hero__panel">
        <p class="hero__eyebrow">Bienvenue sur BiblioConnect</p>
        <h1>Votre espace de lecture moderne</h1>
        <p class="hero__subtitle">Gérez vos livres, suivez vos prêts et accédez rapidement à votre compte depuis un seul endroit.</p>
        <div class="hero__actions">
            <a href="{{ path('app_register') }}" class="btn btn-primary">S'inscrire</a>
            <a href="{{ path('app_login') }}" class="btn btn-secondary">Se connecter</a>
        </div>
    </div>

    <div class="hero__card">
        <div class="hero__card-inner">
            <h2>Commencez dès maintenant</h2>
            <p>Inscrivez-vous pour créer votre bibliothèque personnelle ou connectez-vous pour continuer.</p>
            <div class="hero__stats">
                <div>
                    <strong>100%</strong>
                    <span>Sécurisé</span>
                </div>
                <div>
                    <strong>Instantané</strong>
                    <span>Accès rapide</span>
                </div>
                <div>
                    <strong>Simple</strong>
                    <span>Interface claire</span>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        color: #111827;
        background: radial-gradient(circle at top left, rgba(37, 99, 235, 0.18), transparent 28%),
                    linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
    }

    .hero {
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 3rem 1.5rem;
    }

    .hero__panel,
    .hero__card {
        width: min(1100px, 100%);
        margin: 0 auto;
    }

    .hero__panel {
        max-width: 720px;
        padding: 3rem 3.5rem;
        border-radius: 32px;
        background: rgba(255, 255, 255, 0.92);
        box-shadow: 0 40px 120px rgba(15, 23, 42, 0.12);
        backdrop-filter: blur(18px);
    }

    .hero__eyebrow {
        margin: 0 0 1rem;
        display: inline-flex;
        padding: 0.65rem 1rem;
        border-radius: 999px;
        background: #eef2ff;
        color: #3730a3;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        font-size: 0.85rem;
    }

    .hero h1 {
        margin: 0;
        font-size: clamp(2.8rem, 4vw, 4.5rem);
        line-height: 1.02;
        letter-spacing: -0.05em;
    }

    .hero__subtitle {
        margin: 1.5rem 0 2rem;
        font-size: 1.1rem;
        line-height: 1.8;
        color: #4b5563;
        max-width: 42rem;
    }

    .hero__actions {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 160px;
        padding: 0.95rem 1.5rem;
        border-radius: 999px;
        font-weight: 700;
        text-decoration: none;
        transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
    }

    .btn:hover {
        transform: translateY(-1px);
    }

    .btn-primary {
        background: #4338ca;
        color: #ffffff;
        box-shadow: 0 18px 35px rgba(67, 56, 202, 0.28);
    }

    .btn-secondary {
        background: #ffffff;
        color: #4338ca;
        border: 1px solid rgba(67, 56, 202, 0.16);
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
    }

    .hero__card {
        margin-top: 2rem;
    }

    .hero__card-inner {
        padding: 2.5rem;
        border-radius: 28px;
        background: linear-gradient(180deg, rgba(255,255,255,0.95), rgba(249,250,251,0.95));
        border: 1px solid rgba(148, 163, 184, 0.18);
        box-shadow: 0 30px 90px rgba(15, 23, 42, 0.08);
    }

    .hero__card-inner h2 {
        margin: 0 0 1rem;
        font-size: 1.75rem;
    }

    .hero__card-inner p {
        margin: 0 0 1.75rem;
        color: #475569;
        line-height: 1.75;
    }

    .hero__stats {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    }

    .hero__stats div {
        padding: 1rem 1.15rem;
        border-radius: 18px;
        background: #eef2ff;
    }

    .hero__stats strong {
        display: block;
        font-size: 1.35rem;
        margin-bottom: 0.25rem;
        color: #1e3a8a;
    }

    .hero__stats span {
        color: #475569;
        font-size: 0.95rem;
    }

    @media (max-width: 720px) {
        .hero__panel {
            padding: 2rem;
        }

        .hero__subtitle {
            font-size: 1rem;
        }
    }
</style>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Connexion - BiblioConnect{% endblock %}

{% block body %}
<div class="page-card" style="max-width: 520px; margin: 0 auto;">
    <div class="section-heading">
        <div>
            <h1>Connexion</h1>
            <p class="small-text">Connectez-vous pour accéder à votre espace personnel et réserver vos livres.</p>
        </div>
    </div>

    {% if error %}
        <div class="alert">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}

    {% if app.user %}
        <div class="alert">Vous êtes déjà connecté en tant que {{ app.user.userIdentifier }}.</div>
    {% endif %}

    <form method="post" class="form-card">
        <label for="inputEmail">Email</label>
        <input type="email" value="{{ last_username }}" name="email" id="inputEmail" autocomplete="email" required autofocus>

        <label for="inputPassword">Mot de passe</label>
        <input type="password" name="password" id="inputPassword" autocomplete="current-password" required>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <div style="margin-bottom: 1rem; display:flex; align-items:center; gap:0.5rem;">
            <input type="checkbox" name="_remember_me" id="remember_me">
            <label for="remember_me">Se souvenir de moi</label>
        </div>

        <button class="btn btn-primary" type="submit">Se connecter</button>
    </form>
</div>
{% endblock %}

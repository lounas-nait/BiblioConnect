{% extends 'base.html.twig' %}

{% block title %}Bibliothécaire - BiblioConnect{% endblock %}

{% block body %}
<div class="page-card">
    <div class="section-heading">
        <div>
            <h1>Espace bibliothécaire</h1>
            <p class="small-text">Gérez le catalogue, les auteurs, les catégories et les langues.</p>
        </div>
        <div style="display:flex; gap:0.75rem; flex-wrap:wrap;">
            <a class="btn btn-primary" href="{{ path('librarian_book_new') }}">Ajouter un livre</a>
            <a class="btn btn-secondary" href="{{ path('librarian_auteur_new') }}">Ajouter un auteur</a>
            <a class="btn btn-secondary" href="{{ path('librarian_categorie_new') }}">Ajouter une catégorie</a>
            <a class="btn btn-secondary" href="{{ path('librarian_langue_new') }}">Ajouter une langue</a>
            <a class="btn btn-secondary" href="{{ path('librarian_reservations') }}">Gérer les réservations</a>
        </div>
    </div>

    <section class="item-card">
        <h2>Livres</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1.5rem; margin-bottom: 1rem;">
            {% for livre in livres %}
                <div class="book-card" style="text-align: center;">
                    {% if livre.image %}
                        <img src="{{ livre.image }}" alt="Couverture de {{ livre.titre }}" style="width: 100%; height: 220px; object-fit: cover; border-radius: 12px; margin-bottom: 1rem; box-shadow: 0 10px 25px rgba(15, 23, 42, 0.15);">
                    {% else %}
                        <div style="width: 100%; height: 220px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 12px; margin-bottom: 1rem; display: flex; align-items: center; justify-content: center; color: white; font-size: 2.5rem;">📚</div>
                    {% endif %}
                    <h3 style="margin: 0.5rem 0; font-size: 1rem;">{{ livre.titre }}</h3>
                    <div class="small-text">{{ livre.auteur }}</div>
                    <div class="small-text">Stock : <strong>{{ livre.stock }}</strong></div>
                    <a class="btn btn-secondary" href="{{ path('librarian_book_edit', {'id': livre.id}) }}" style="margin-top: 0.75rem; display: inline-block;">Modifier</a>
                </div>
            {% else %}
                <p class="small-text">Aucun livre dans le catalogue.</p>
            {% endfor %}
        </div>
    </section>

    <div class="admin-grid" style="margin-top:1.5rem;">
        <section class="item-card">
            <h2>Auteurs</h2>
            <ul>
                {% for auteur in auteurs %}
                    <li>{{ auteur }}</li>
                {% else %}
                    <p class="small-text">Aucun auteur ajouté.</p>
                {% endfor %}
            </ul>
        </section>

        <section class="item-card">
            <h2>Catégories</h2>
            <ul>
                {% for categorie in categories %}
                    <li>{{ categorie.nom }}</li>
                {% else %}
                    <p class="small-text">Aucune catégorie ajoutée.</p>
                {% endfor %}
            </ul>
        </section>

        <section class="item-card">
            <h2>Langues</h2>
            <ul>
                {% for langue in langues %}
                    <li>{{ langue.nom }}</li>
                {% else %}
                    <p class="small-text">Aucune langue ajoutée.</p>
                {% endfor %}
            </ul>
        </section>
    </div>
</div>
{% endblock %}
